{
  "name": "sample-api",
  "version": "1.0.0",
  "description": "A layered TypeScript order-management REST API used as a benchmark fixture for AI dev tools.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
